NODE_ENV=development

# API
PORT=4000
JWT_SECRET=dev_jwt_secret_please_change
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
STORAGE_MODE=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nintendo_gametime
OTP_EXPIRES_MINUTES=10
OTP_DEV_CODE=000000
INTERNAL_SYNC_TOKEN=internal_sync_token_change_me
NINTENDO_MOCK=true
ALERT_FAIL_THRESHOLD=3
R_VISUALIZATION_ENABLED=true
R_VISUALIZATION_BIN=Rscript
R_VISUALIZATION_TIMEOUT_MS=3000

# Worker
API_BASE_URL=http://localhost:4000
SYNC_INTERVAL_MS=300000

# Web
VITE_API_BASE_URL=http://localhost:4000
