NODE_ENV=development
PORT=4000
JWT_SECRET=dev_jwt_secret_please_change
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
STORAGE_MODE=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nintendo_gametime?sslmode=disable
OTP_EXPIRES_MINUTES=10
OTP_DEV_CODE=000000
INTERNAL_SYNC_TOKEN=internal_sync_token_change_me
NINTENDO_MOCK=true
API_BASE_URL=http://localhost:4000

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# R Visualization
R_VISUALIZATION_ENABLED=true
R_VISUALIZATION_BIN=Rscript
R_VISUALIZATION_TIMEOUT_MS=3000

# eShop Crawler
ESHOP_CACHE_TTL_MS=21600000
ESHOP_RATE_LIMIT_MS=1200
CRAWLER_DISCOVER_INTERVAL_MS=43200000
CRAWLER_PRICE_REFRESH_INTERVAL_MS=7200000
CRAWLER_STALE_PRICE_MS=21600000
CRAWLER_BATCH_LIMIT=50
CATALOG_REFRESH_INTERVAL_MS=21600000
ALERT_FAIL_THRESHOLD=3
